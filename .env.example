# ArtCracker API Authentication
TOKEN=your_artcracker_api_token_here

# Classifier Configuration
CLASSIFIER_MODEL=google/siglip2-base-patch16-512
# Threshold for classification
# - Uses sigmoid probabilities (range: 0.0 to 1.0)
# - Computed as: sigmoid(cosine_similarity * logit_scale + logit_bias)
# - Recommended: 0.35-0.50 for good balance between precision and recall
# - Higher threshold = more strict (fewer false positives, more "other" classifications)
# - Lower threshold = more permissive (fewer "other", more false positives)
CLASSIFIER_THRESHOLD=0.4
CATEGORIES_FILE=config/categories.json

# Logging Configuration
# Set to DEBUG to see detailed embedding comparison results
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO